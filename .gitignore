# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# venv / uv
.venv/
.python-version

# IDE
.vscode/
.idea/

# MkDocs build
site/

# Local snapshots (large; produced by tools/freeze_snapshot.py)
# Keep folder structure with .gitkeep, ignore actual data
snapshots/**/raw/
snapshots/**/gold/
snapshots/**/landed/
snapshots/**/vendor/
!snapshots/**/.gitkeep
!snapshots/**/README.md

# Diff reports
diff_report*.html
diff_report*.json

# Secrets
.env
.env.*
!.env.example

# G2a snapshot outputs (Parquet via Git LFS once configured; SQL + manifest tracked separately)
baselines/**/input_snapshots/parquet/
baselines/**/input_snapshots/csv/

# Legacy runner outputs (XLSX, logs, metadata — never committed)
runs/*
!runs/.gitkeep

# Next.js frontend (apps/web)
apps/web/node_modules/
apps/web/.next/
apps/web/out/
apps/web/.env.local
apps/web/next-env.d.ts
apps/web/*.tsbuildinfo

