# G2a operator environment
# Copy to .env and fill in actual values. .env is gitignored.
# Usage: cp .env.example .env  (then edit .env — never commit .env)

# HashiCorp Vault
VAULT_ADDR=https://<vault-host>:8200
VAULT_TOKEN=<your-vault-token-here>
VAULT_REDSHIFT_PATH=prefect-secret/db/redshift

# Anchor dates for MRC 2026-04-30 freeze
G2A_SERVICER=mrc
G2A_REMIT_DATE=2026-04-30
G2A_FCTRDT=2026-05-01
G2A_FCTRDT_1M=2026-04-01
